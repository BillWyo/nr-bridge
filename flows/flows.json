  {
    "id": "his-fn-grubbs",
    "type": "function",
    "z": "his-flow-main",
    "name": "Grubbs filter",
    "func": "var N=20,N_MIN=16;\nvar G_CRIT={3:1.155,4:1.481,5:1.715,6:1.887,7:2.020,8:2.126,9:2.215,10:2.290,11:2.355,12:2.412,13:2.462,14:2.507,15:2.549,16:2.585,17:2.620,18:2.651,19:2.681,20:2.709,25:2.822,30:2.908};\nfunction gcrit(n){if(G_CRIT[n])return G_CRIT[n];var k=Object.keys(G_CRIT).map(Number).sort(function(a,b){return a-b;});for(var i=0;i<k.length-1;i++){if(n>=k[i]&&n<=k[i+1]){var t=(n-k[i])/(k[i+1]-k[i]);return G_CRIT[k[i]]+t*(G_CRIT[k[i+1]]-G_CRIT[k[i]]);}}return G_CRIT[20];}\nfunction grubbs(win,val){var n=win.length;if(n<N_MIN)return false;var mean=win.reduce(function(a,b){return a+b;},0)/n;var std=Math.sqrt(win.reduce(function(a,b){return a+Math.pow(b-mean,2);},0)/(n-1));if(std<1e-10)return false;return(Math.abs(val-mean)/std)>gcrit(n);}\nvar nodeId=msg.topic.split('/')[1];\nvar d=msg.payload;\nvar key='grubbs_'+nodeId;\nvar st=flow.get(key)||{P:{win:[],faults:0},T:{win:[],faults:0},RH:{win:[],faults:0}};\nvar anyFault=false;\nvar result={};\n['P','T','RH'].forEach(function(p){var s=st[p],v=d[p];if(typeof v!=='number'||isNaN(v)){result[p]={outlier:true};s.faults++;anyFault=true;return;}if(grubbs(s.win,v)){result[p]={outlier:true};s.faults++;anyFault=true;}else{s.win.push(v);if(s.win.length>N)s.win.shift();result[p]={outlier:false,value:v};}});\nflow.set(key,st);\nfunction mk(p){var r=result[p];if(r.outlier)return null;return{topic:anyFault?nodeId+'-c':nodeId,payload:r.value,_nodeId:nodeId};}\nreturn[mk('P'),mk('T'),mk('RH'),{payload:{nodeId:nodeId,P:st.P.faults,T:st.T.faults,RH:st.RH.faults}}];",
    "outputs": 4,
    "noerr": 0,
    "x": 380,
    "y": 120,
    "wires": [
      [
        "his-fn-p-diffs"
      ],
      [
        "v2-chart-temp"
      ],
      [
        "his-fn-rh-summary"
      ],
      [
        "his-fn-fault-collect"
      ]
    ]
  },
  {
    "id": "his-fn-rh-summary",
    "type": "function",
    "z": "his-flow-main",
    "name": "RH summary",
    "func": "var nodeId=msg._nodeId||msg.topic.replace(/-c$/,'');var latest=flow.get('rh_latest')||{};latest[nodeId]=msg.payload;flow.set('rh_latest',latest);var nodes=['bills-office','mud-room','garage'];var labels={'bills-office':'Bills Office','mud-room':'Mud Room','garage':'Garage'};var readings=nodes.map(function(n){return{label:labels[n],value:latest[n]!==undefined?latest[n].toFixed(1)+'%':'--'};});msg.payload=readings;return msg;",
    "outputs": 1,
    "noerr": 0,
    "x": 620,
    "y": 160,
    "wires": [
      [
        "v2-tmpl-rh"
      ]
    ]
  },
  {
    "id": "his-fn-p-diffs",
    "type": "function",
    "z": "his-flow-main",
    "name": "P differences",
    "func": "var STALE_MS=300000,N_CONF_MIN=16,WIN=60,TREND_WIN=30,TREND_THRESH=0.003;\nvar nodeId=msg._nodeId||msg.topic.replace(/-c$/,'');\nvar latest=flow.get('p_latest')||{};\nlatest[nodeId]={v:msg.payload,t:Date.now()};\nflow.set('p_latest',latest);\nvar nodes=['bills-office','mud-room','garage'];\nif(!nodes.every(function(n){return latest[n];}))return null;\nvar stats=flow.get('p_diff_stats')||{'BO-MR':{win:[],mean:0,std:0},'BO-GA':{win:[],mean:0,std:0},'MR-GA':{win:[],mean:0,std:0}};\nvar pairs={'BO-MR':latest['bills-office'].v-latest['mud-room'].v,'BO-GA':latest['bills-office'].v-latest['garage'].v,'MR-GA':latest['mud-room'].v-latest['garage'].v};\nObject.keys(pairs).forEach(function(k){var d=pairs[k],s=stats[k];s.win.push(d);if(s.win.length>WIN)s.win.shift();var n=s.win.length;s.mean=s.win.reduce(function(a,b){return a+b;},0)/n;s.std=n>1?Math.sqrt(s.win.reduce(function(a,b){return a+Math.pow(b-s.mean,2);},0)/(n-1)):0;});\nflow.set('p_diff_stats',stats);\nvar now=Date.now();\nvar primary=null,primaryNode=null;\nfor(var i=0;i<nodes.length;i++){var e=latest[nodes[i]];if(e&&(now-e.t)<STALE_MS){primary=e.v;primaryNode=nodes[i];break;}}\nif(primary===null)return null;\nvar tb=flow.get('p_trend_buf')||[];\ntb.push({v:primary,t:now});if(tb.length>TREND_WIN)tb.shift();\nflow.set('p_trend_buf',tb);\nvar trendStr='\u2192 stable';\nif(tb.length>=2){var dt=(tb[tb.length-1].t-tb[0].t)/3600000;var dv=tb[tb.length-1].v-tb[0].v;var rate=dt>0?dv/dt:0;if(rate>TREND_THRESH)trendStr='\u2191 +'+rate.toFixed(3)+' PSI/hr';else if(rate<-TREND_THRESH)trendStr='\u2193 '+rate.toFixed(3)+' PSI/hr';}\nvar minN=Math.min.apply(null,Object.keys(stats).map(function(k){return stats[k].win.length;}));\nvar confStr='calibrating (N='+minN+'/16)';\nif(minN>=N_CONF_MIN){var maxStd=Math.max.apply(null,Object.keys(stats).map(function(k){return stats[k].std;}));var pct=(3*maxStd/primary)*100;confStr='\u00b1 '+pct.toFixed(2)+'%';}\nmsg.payload={pressure:primary.toFixed(3),source:primaryNode,trend:trendStr,conf:confStr};\nreturn msg;",
    "outputs": 1,
    "noerr": 0,
    "x": 620,
    "y": 220,
    "wires": [
      [
        "v2-tmpl-pressure"
      ]
    ]
  },
  {
    "id": "his-fn-fault-collect",
    "type": "function",
    "z": "his-flow-main",
    "name": "collect faults",
    "func": "var d=msg.payload;\nvar counts=flow.get('fault_counts')||{};\n['bills-office','mud-room','garage'].forEach(function(n){if(!counts[n])counts[n]={P:0,T:0,RH:0};});\ncounts[d.nodeId]={P:d.P,T:d.T,RH:d.RH};\nflow.set('fault_counts',counts);\nmsg.payload=counts;\nreturn msg;",
    "outputs": 1,
    "noerr": 0,
    "x": 620,
    "y": 300,
    "wires": [
      [
        "v2-tmpl-faults"
      ]
    ]
  },
