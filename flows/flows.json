    { "id": "his-inject-reset-all", "type": "inject", "z": "his-flow-main", "name": "Reset ALL",          "props": [{"p":"payload"}], "repeat": "", "crontab": "", "once": false, "payload": "ALL",          "payloadType": "str", "x": 200, "y": 1000, "wires": [["his-fn-grubbs-reset"]] },
    {
        "id": "his-fn-grubbs-reset",
        "type": "function",
        "z": "his-flow-main",
        "name": "reset Grubbs state",
        "func": "var nodes = ['bills-office','mud-room','garage'];\nvar counts = flow.get('fault_counts') || {};\nnodes.forEach(function(n){ if(!counts[n]) counts[n]={P:0,T:0,RH:0}; });\nif (msg.payload === 'ALL') {\n    nodes.forEach(function(n) { flow.set('grubbs_' + n, null); counts[n]={P:0,T:0,RH:0}; });\n    flow.set('p_latest', null);\n    flow.set('p_diff_stats', null);\n    flow.set('p_trend_buf', null);\n    node.warn('Grubbs reset: ALL nodes');\n} else {\n    flow.set('grubbs_' + msg.payload, null);\n    counts[msg.payload] = {P:0, T:0, RH:0};\n    node.warn('Grubbs reset: ' + msg.payload);\n}\nflow.set('fault_counts', counts);\nreturn null;",
        "outputs": 0,
        "noerr": 0,
        "x": 480, "y": 940,
        "wires": []
    },

