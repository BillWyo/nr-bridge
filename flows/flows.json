  {
    "id": "8db92d9dccf5b93b",
    "type": "template",
    "z": "his-flow-main",
    "name": "voice_ui_page",
    "field": "payload",
    "fieldType": "msg",
    "format": "handlebars",
    "syntax": "mustache",
    "template": "<!DOCTYPE html>\n<html>\n<head>\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n    <title>Voice to Node-RED</title>\n    <style>\n        body { font-family: sans-serif; padding: 30px; background: #1a1a2e; color: white; max-width: 500px; margin: 0 auto; }\n        h2 { text-align: center; margin-bottom: 30px; }\n        textarea { width: 100%; font-size: 18px; padding: 15px; border-radius: 10px; border: none; min-height: 120px; box-sizing: border-box; background: #16213e; color: white; }\n        button { width: 100%; margin-top: 15px; font-size: 22px; padding: 20px; border-radius: 50px; background: #e94560; color: white; border: none; }\n        #status { text-align: center; margin-top: 20px; font-size: 16px; color: #aaa; min-height: 24px; }\n    </style>\n</head>\n<body>\n    <h2>Voice to Node-RED</h2>\n    <textarea id=\"txt\" placeholder=\"Tap the mic on your keyboard and speak...\"></textarea>\n    <button onclick=\"send()\">Send</button>\n    <div id=\"status\"></div>\n    <script>\n        function send() {\n            var text = document.getElementById('txt').value.trim();\n            if (!text) return;\n            document.getElementById('status').textContent = 'Sending...';\n            fetch('/voice', {\n                method: 'POST',\n                headers: { 'Content-Type': 'application/json' },\n                body: JSON.stringify({ text: text })\n            }).then(function() {\n                document.getElementById('status').textContent = 'Sent!';\n                document.getElementById('txt').value = '';\n            }).catch(function() {\n                document.getElementById('status').textContent = 'Error \u00e2\u20ac\u201d check Node-RED';\n            });\n        }\n    </script>\n</body>\n</html>\n",
    "output": "str",
    "x": 1260,
    "y": 400,
    "wires": [
      [
        "2255e6a229deff89",
        "c7432bc008d82fc8"
      ]
    ]
