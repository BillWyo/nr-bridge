        "type": "inject",
        "z": "his-flow-main",
        "name": "watchdog tick",
        "props": [{"p": "payload"}],
        "repeat": "60",
        "crontab": "",
        "once": true,
        "onceDelay": 10,
        "payload": "",
        "payloadType": "date",
        "x": 180, "y": 1060,
